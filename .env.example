# Copy to .env and fill in real values. NEVER commit .env (see .gitignore).
# AISDP #1: secrets live in the deployment environment, not in the repo.

NODE_ENV=development
PORT=3000

# Comma-separated EXACT origins (scheme://host[:port]). No wildcards.
ALLOWED_ORIGINS=http://localhost:5173

# --- Secrets (required in production; the app refuses to boot without them) ---

# HS256 signing key for 15-minute access tokens. >= 32 bytes.
# Generate with: openssl rand -base64 48
JWT_SECRET=

# HMAC pepper for refresh-token digests stored in the database.
# Generate with: openssl rand -base64 48
REFRESH_TOKEN_PEPPER=

# --- JWT claims (must match across services that verify these tokens) ---
JWT_ISSUER=https://auth.ai-secure-apps.local
JWT_AUDIENCE=ai-secure-apps-api

# --- Rate limits (sliding window) ---
# General API: max requests per window per user/IP.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
# Auth endpoints (login/refresh/logout): tighter per-IP budget.
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10

# SQLite database file (defaults to in-memory for dev/tests).
# DATABASE_FILE=./data/app.sqlite
